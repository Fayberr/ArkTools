{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArkTools",
  "version": "1.5.7",
  "identifier": "ArkTools",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run frontend:build",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ArkTools",
        "width": 560,
        "height": 420,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 300,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://arktools.fayber.dev/api/updater/win64.json",
        "https://github.com/Fayberr/ArkTools/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyREY0RTc2QTU4Qjc1N0UKUldSK2RZdWxkazdmSW1IQmI4ZVMwOTRzWnBiVENhMFNYMFRtN0V4R3N0Q2JXQUdqM2t4VnRnNUYK"
    },
    "bundle": {
      "active": true,
      "targets": "nsis",
      "createUpdaterArtifacts": false,
      "publisher": "Fayberr",
      "copyright": "Copyright (c) Fayberr",
      "category": "Utility",
      "shortDescription": "Premade macro launcher for ARK.",
      "longDescription": "Extensible premade macro launcher for ARK with global hotkeys and overlay calibration.",
      "homepage": "https://github.com/Fayberr/ArkTools",
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        },
        "nsis": {
          "compression": "zlib"
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
